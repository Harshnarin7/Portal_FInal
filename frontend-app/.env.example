# ============================================================================
# PORTAL Trial Frontend - Environment Configuration
# ============================================================================
# Copy this file to .env.local (for local dev) or set as build env vars on AWS
# IMPORTANT: Run `npm run build` AFTER setting these — the URL is baked into
# the React bundle at build time.
# ============================================================================

# Backend API URL — must be your AWS backend URL (no trailing slash)
# Local dev:      http://localhost:8000
# AWS EC2/ECS:    http://<your-ec2-public-ip>:8000
# AWS with domain: https://api.portaltrial.in
REACT_APP_API_URL=https://api.portaltrial.in
