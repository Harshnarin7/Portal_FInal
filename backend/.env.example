# ============================================================================
# PORTAL TRIAL APPLICATION - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in the actual values for your deployment
# DO NOT commit the actual .env file to Git
# ============================================================================

# ============================================================================
# SECURITY - SECRET KEY (CRITICAL)
# ============================================================================
# Generate a strong secret key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This is used to sign JWT authentication tokens
SECRET_KEY=your-strong-random-secret-key-here-min-32-chars

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://portal_user:secure_password@localhost:5432/portal_trial_db

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed origins for cross-origin requests (comma-separated)
# Only these domains can make requests to the API from a browser
ALLOWED_ORIGINS=https://portaltrial.in,https://www.portaltrial.in,http://localhost:3000

# ============================================================================
# FIREBASE CONFIGURATION (Optional)
# ============================================================================
# If using Firebase for authentication/database
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (set to False in production)
DEBUG=False

# Application host and port
APP_HOST=0.0.0.0
APP_PORT=9000

# ============================================================================
# LOGGING & MONITORING (Optional)
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# AWS CloudWatch (optional for production monitoring)
AWS_REGION=ap-south-1
AWS_CLOUDWATCH_LOG_GROUP=/portal-trial/api

# Security monitoring thresholds (JSON logs on stdout → CloudWatch)
SECURITY_FAILED_LOGIN_THRESHOLD=10
SECURITY_FAILED_LOGIN_WINDOW=900
SECURITY_BULK_LIST_THRESHOLD=100

# ============================================================================
# RATE LIMITING (Optional, for future implementation)
# ============================================================================
# Redis URL for rate limiting (optional)
REDIS_URL=redis://localhost:6379/0

# Max login attempts before temporary lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
