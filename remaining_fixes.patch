diff --git a/nginx.conf b/nginx.conf
index cb9c449..174f08d 100644
--- a/nginx.conf
+++ b/nginx.conf
@@ -1,3 +1,21 @@
+# ── API subdomain — proxies bare backend paths (mobile app + REACT_APP_API_URL) ─
+# Matches deploy.sh / .env.example's REACT_APP_API_URL=https://api.portaltrial.in.
+# Requires a DNS "A" record for api.portaltrial.in pointing at this server's IP
+# before this block will do anything (it doesn't create the DNS record itself).
+server {
+    listen 80;
+    server_name api.portaltrial.in;
+
+    location / {
+        proxy_pass http://127.0.0.1:8000/;
+        proxy_set_header Host $host;
+        proxy_set_header X-Real-IP $remote_addr;
+        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
+        proxy_set_header X-Forwarded-Proto $scheme;
+        proxy_read_timeout 120s;
+    }
+}
+
 server {
     listen 80;
     server_name portaltrial.in www.portaltrial.in;  # ← replace with your domain or EC2 public IP
